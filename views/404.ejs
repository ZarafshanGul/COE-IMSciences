<!DOCTYPE html>
<html lang="en">
<head><%- include('partials/head', { pageTitle: pageTitle }) %></head>
<body>
<div class="page-bg"></div>
<%- include('partials/header') %>

<main class="d-flex align-items-center justify-content-center" style="min-height:60vh;">
  <div class="container-xxl px-3">
    <div class="row justify-content-center">
      <div class="col-12 col-sm-8 col-md-6 col-lg-4">
        <div class="notfound-card p-5 text-center">
          <p class="mb-1" style="color:var(--text-faint); font-size:0.875rem;">Error</p>
          <h1 class="fw-bold mb-2" style="font-size:4rem; color:var(--secondary);">404</h1>
          <p class="fw-semibold mb-1" style="font-size:1.1rem;">Page not found</p>
          <p class="mb-4" style="color:var(--text-light); font-size:0.9rem;">
            The page you are looking for does not exist.
          </p>
          <a href="/" class="btn btn-brand rounded-pill px-5 py-2 fw-bold">
            Back to Home
          </a>
        </div>
      </div>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
<%- include('partials/scripts') %>
</body>
</html>
